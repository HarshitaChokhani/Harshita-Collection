# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# --- Supabase (publishable/anon keys — safe for the browser) ---
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_URL="https://your-project-id.supabase.co"
# VITE_ vars are exposed to the browser at build time — public config only.
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# --- Server-only secrets (NEVER prefix with VITE_) ---
# Razorpay payment gateway
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
# Anthropic API key — powers "Autofill from image" in the admin product editor.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=""
